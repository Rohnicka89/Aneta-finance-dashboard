{
  "name": "aneta-finance-dashboard",
  "private": true,
  "version": "1.0.0",
  "description": "Anetin osobní finanční dashboard pro Raiffeisenbank",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "wrangler pages deploy dist",
    "db:create": "wrangler d1 create aneta-finance-db",
    "db:migrate": "wrangler d1 migrations apply aneta-finance-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply aneta-finance-db --remote"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "lucide-react": "^0.383.0",
    "pdfjs-dist": "^3.11.174"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.0",
    "wrangler": "^3.78.0"
  }
}
